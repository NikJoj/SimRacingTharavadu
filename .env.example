# Environment Variables Template
# Copy this file to .env.local for local development
# For production, set these in Vercel Dashboard → Settings → Environment Variables

# ============================================
# ADMIN AUTHENTICATION
# ============================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here
JWT_SECRET=your_random_32_character_secret_key_here

# ============================================
# VERCEL BLOB STORAGE
# ============================================
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# ============================================
# GITHUB POSTER SYNC (NEW)
# ============================================
# Get your token from: https://github.com/settings/tokens
# Required scope: repo (Full control of private repositories)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_OWNER=your_github_username
GITHUB_REPO=SimRacingTharavadu
GITHUB_BRANCH=main

# ============================================
# NOTES
# ============================================
# - Never commit .env.local or .env files to git
# - Keep your tokens secure and rotate them periodically
# - For production deployment, use Vercel's environment variables UI
# - You can use the automated setup: npm run setup:github